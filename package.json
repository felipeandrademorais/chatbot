{
  "name": "chatbot",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "pnpm": "9.15.4"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "openapi:lint": "node scripts/openapi-lint.mjs",
    "contract:compat": "node scripts/contract-compat.mjs",
    "typecheck": "pnpm -r run typecheck",
    "test:unit": "pnpm -r run test:unit",
    "test:integration": "vitest run tests/integration",
    "test:contract": "vitest run tests/contract && pnpm -r run --if-present test:contract",
    "test:security": "vitest run tests/security",
    "test:smoke": "vitest run tests/smoke",
    "test:regression": "bash scripts/run-regression-matrix.sh",
    "test:performance": "vitest run tests/regression tests/e2e",
    "test:chaos": "bash scripts/run-chaos-drills.sh",
    "test:rollback": "bash scripts/run-rollback-rehearsal.sh",
    "contract:freeze": "bash scripts/enforce-contract-freeze.sh",
    "release:readiness": "pnpm run test:regression && pnpm run test:chaos && pnpm run test:rollback",
    "migrate": "pnpm --filter @chatbot/shared run build && pnpm --filter @chatbot/shared run migrate",
    "compose:dev": "docker compose --profile dev up -d --build",
    "compose:test": "docker compose --profile test up -d --build --wait",
    "compose:down": "docker compose --profile dev --profile test down -v",
    "test:e2e": "vitest run tests/e2e",
    "quality:gate": "bash scripts/quality-gate.sh",
    "clean": "pnpm -r run --if-present clean && rm -rf node_modules",
    "readiness:check": "bash scripts/check-project-readiness.sh",
    "commitlint": "commitlint"
  },
  "devDependencies": {
    "axe-core": "^4.11.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@chatbot/contracts": "workspace:*",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.2",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "fastify": "^5.6.2",
    "eslint": "^9.28.0",
    "jsdom": "^26.1.0",
    "pg": "^8.16.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.2.1"
  }
}
