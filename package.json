{
  "name": "chatbot",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r run typecheck",
    "test:unit": "pnpm -r run test:unit",
    "test:integration": "pnpm -r run --if-present test:integration",
    "test:contract": "pnpm -r run --if-present test:contract",
    "test:smoke": "pnpm -r run --if-present test:smoke",
    "test:e2e": "pnpm -r run --if-present test:e2e",
    "clean": "pnpm -r run --if-present clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.15.21",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^3.2.1"
  }
}
