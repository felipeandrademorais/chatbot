{
  "name": "@chatbot/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "migrate": "node ./dist/migrations/cli.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@chatbot/contracts": "workspace:*",
    "@chatbot/domain": "workspace:*",
    "fastify": "^5.3.3",
    "pg": "^8.16.0",
    "prom-client": "^15.1.3",
    "redis": "^5.5.6",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/pg": "^8.15.2",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
