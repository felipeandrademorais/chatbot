# =============================================================================
# Chatbot Platform - Environment Configuration
# =============================================================================
# Copy to .env and set POSTGRES_PASSWORD before starting compose.
# NEVER commit .env to version control.
# =============================================================================

# --- Required ---
POSTGRES_PASSWORD=change-me
JWT_SECRET=change-me-super-secret

# --- Host publish ports (your machine → container) ---
# Defaults avoid clashes with a local Postgres (5432) or Redis (6379).
# Apps inside compose always use postgres:5432 and redis:6379 on the Docker network.
POSTGRES_PUBLISH_PORT=5433
REDIS_PUBLISH_PORT=6380

# --- Used when connecting from the host (psql, migrate CLI) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=chatbot
POSTGRES_DB=chatbot

REDIS_HOST=localhost
REDIS_PORT=6380

NODE_ENV=development
LOG_LEVEL=info

GATEWAY_PORT=3000
ORCHESTRATOR_PORT=3001
WORKER_PORT=3002
WEB_PORT=3003
# Web → gateway API (workflow create/view/retry) when running apps on the host:
WORKFLOW_API_BASE_URL=http://localhost:3000
# Docker Compose sets http://gateway:3000 on the web service (see docker-compose.yml).
# Do not rely on this host value inside the web container — localhost there is the web app.

# Stage 09 scalability tuning
RATE_LIMIT_WINDOW_MS=1000
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_BURST_ALLOWANCE=30
# Local Ollama cold start: first /internal/provider/generate may load the model; 60s avoids 503 provider_unavailable (compose default matches).
RETRY_TIMEOUT_MS=60000
RETRY_MAX_RETRIES=2
RETRY_BACKOFF_MULTIPLIER=2
RETRY_MAX_BACKOFF_MS=8000
WORKER_TARGET_TPS=40
WORKER_AVERAGE_JOB_LATENCY_MS=150
WORKER_MAX_CONCURRENCY=32
QUEUE_PARTITION_KEYS=workflowId,taskType
QUEUE_MAX_IN_FLIGHT_PER_PARTITION=8
CACHE_DEFAULT_TTL_MS=30000
CACHE_STALE_REVALIDATE_MS=5000

# Inside compose, gateway reaches orchestrator by service name:
ORCHESTRATOR_URL=http://orchestrator:3001

# Ollama (local LLM) — host vs Docker:
# - From the host (pnpm start, vitest): use localhost.
# - From compose on macOS/Windows Docker Desktop: use host.docker.internal so containers reach host Ollama.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_APPROVED_MODELS=gemma4:e2b,gemma4:e4b
OLLAMA_FALLBACK_MODEL=gemma4:e4b
# Set true to never call /api/pull (models must already be installed via `ollama list`).
# OLLAMA_SKIP_PULL=true
